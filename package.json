  "type": "module",
  "scripts": {
    "dev": "concurrently -n streams,app -c cyan,magenta --kill-others-on-fail \"pnpm dev:streams\" \"pnpm dev:app\"",
    "dev:app": "dotenv -e .env.local -e .env -- portless run vite dev",
    "dev:streams": "dotenv -e .env.local -e .env -- tsx scripts/durable-streams-server.ts",
    "build": "vite build",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "typecheck": "vite build",
    "ci": "pnpm fmt:check && pnpm lint && pnpm typecheck && pnpm build",
    "start": "node .output/server/index.mjs",
    "eval:agent-runtime": "tsx scripts/evals/agent-runtime.ts",
    "db:generate": "dotenv -e .env.local -e .env -- drizzle-kit generate",
    "db:studio": "dotenv -e .env.local -e .env -- drizzle-kit studio",
    "db:backfill-previews": "dotenv -e .env.local -e .env -- tsx scripts/backfill-message-part-previews.ts"
  },
