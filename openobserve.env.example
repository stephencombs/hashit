# Copy the values you want into `.env.local` for local development.
#
# The telemetry layer will derive:
# - OTLP logs:   ${OPENOBSERVE_URL}/api/${OPENOBSERVE_ORG}/v1/logs
# - OTLP traces: ${OPENOBSERVE_URL}/api/${OPENOBSERVE_ORG}/v1/traces
#
# If you set explicit OTLP_* / OTEL_* variables, those take precedence.

OPENOBSERVE_URL=http://localhost:5080
OPENOBSERVE_ORG=default
OPENOBSERVE_ROOT_USER_EMAIL=root@example.com
OPENOBSERVE_ROOT_USER_PASSWORD=openobserve-dev-password

# Optional: sets the `stream-name` header for OTLP log ingestion.
OPENOBSERVE_STREAM_NAME=hashit

# Optional explicit service name for traces/resources.
OTEL_SERVICE_NAME=hashit
